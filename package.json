{
  "name": "phantomcat-landing",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web build && pnpm --filter worker dev",
    "deploy": "pnpm --filter web build && pnpm --filter worker deploy",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\" --ignore-path .gitignore",
    "prepare": "pnpm approve-builds --all"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
